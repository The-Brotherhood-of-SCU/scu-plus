{
  "extends": "plasmo/templates/tsconfig.base.json",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "types": ["chrome"],
    "paths": {
      "~*": ["./src/*"],
      "package.json": ["./package.json"]
    }
  }
}